{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "albums"
  ],
  "properties": {
    "albums": {
      "type": "object",
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "album_type",
              "total_tracks",
              "id",
              "name",
              "release_date",
              "release_date_precision",
              "type",
              "uri",
              "artists"
            ],
            "properties": {
              "album_type": {
                "type": "string",
                "enum": [
                  "album",
                  "single",
                  "compilation"
                ]
              },
              "total_tracks": {
                "type": "integer"
              },
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "release_date": {
                "type": "string"
              },
              "release_date_precision": {
                "type": "string",
                "enum": [
                  "year",
                  "month",
                  "day"
                ]
              },
              "type": {
                "type": "string"
              },
              "uri": {
                "type": "string",
                "pattern": "^spotify:album:.*"
              },
              "artists": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "name"
                  ],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}